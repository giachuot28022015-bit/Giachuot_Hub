SubmitBtn.MouseButton1Click:Connect(function()
    SubmitBtn.Text = "ĐANG CHECK..."
    local url = "https://giachuothub-key-sever.vercel.app/api/check-key?key=" .. KeyInput.Text
    local success, response = pcall(function() return game:HttpGet(url) end)
    
    if success and string.find(string.lower(tostring(response)), "true") then
        StarterGui:SetCore("SendNotification", {Title="Thành công", Text="Xác thực key thành công✅", Duration=3})
        KeyFrame:Destroy()
        LoadMainHub()
    else
        SubmitBtn.Text = "SUBMIT KEY"
        StarterGui:SetCore("SendNotification", {Title="Thông báo", Text="Key sai hoặc đã hết hạn❌", Duration=3})
    end
end)
